// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  trainer
  player
  sportlover
}

enum Sport {
  football
  basketball
  volleyball
  taekwondo
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  player       Player?
  trainedTeam  Team?        @relation("TeamTrainer")

  @@map("users")
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  age       Int?
  gender    String?
  sport     Sport
  position  String?
  stats     Json?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teamId Int?
  team   Team?   @relation(fields: [teamId], references: [id])
  userId Int?    @unique
  user   User?   @relation(fields: [userId], references: [id])

  @@map("players")
}

model Federation {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  sport        Sport
  teams        Team[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("federations")
}

model Team {
  id           Int        @id @default(autoincrement())
  name         String
  sport        Sport
  gender       String
  federationId Int
  trainerId    Int        @unique
  logoUrl      String?
  stats        Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  players      Player[]
  federation   Federation @relation(fields: [federationId], references: [id])
  trainer      User       @relation("TeamTrainer", fields: [trainerId], references: [id])
  homeMatches  Match[]   @relation("HomeTeam")
  awayMatches  Match[]   @relation("AwayTeam")

  @@map("teams")
}

model Match {
  id         Int        @id @default(autoincrement())
  date       DateTime
  score      String?
  status     String     @default("scheduled") // scheduled, live, completed
  venue      String?
  federation String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  team1Id Int
  team1   Team @relation("HomeTeam", fields: [team1Id], references: [id])
  team2Id Int
  team2   Team @relation("AwayTeam", fields: [team2Id], references: [id])

  @@map("matches")
}

model News {
  id          Int        @id @default(autoincrement())
  title       String
  description String
  content     String?
  imageUrl    String?
  link        String?
  federation  String
  date        DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("news")
}

model ScrapingLog {
  id         Int        @id @default(autoincrement())
  federation String
  status     String     // success, failed
  message    String?
  itemsCount Int        @default(0)
  createdAt  DateTime   @default(now())

  @@map("scraping_logs")
}
